generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum CollectionScope {
  FEATURED
  PERSONAL
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())

  accounts Account[]
  sessions Session[]

  timelines Timeline[]
  collections Collection[]
  feedbacks Feedback[]
}

model Timeline {
  id          String @id @default(cuid())
  title       String
  description String
  category    String   @default("General")
  tags        String[] @default([])

  isApproved Boolean  @default(false)
  isFeatured Boolean  @default(false)
  coverImage String?
  createdAt  DateTime @default(now())

  userId String

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  timelineEvents TimelineEvent[]
}

model TimelineEvent {
  id          String   @id @default(cuid())
  title       String
  description String
  date        DateTime?
  displayDate String?
  historicalYear  Int?
  historicalMonth Int?
  historicalDay   Int?
  datePrecision   String?
  isApproximate   Boolean  @default(false)
  locationData Json?
  mediaData    Json?

  createdAt DateTime @default(now())

  timelineId String
  timeline   Timeline @relation(fields: [timelineId], references: [id], onDelete: Cascade)
  collectionEvents CollectionEvent[]

  @@index([timelineId])
  @@index([historicalYear, historicalMonth, historicalDay])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Feedback {
  id        String   @id @default(cuid())
  content   String   @db.Text
  type      String   @default("General")
  createdAt DateTime @default(now())

  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Collection {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  scope  CollectionScope @default(PERSONAL)

  collectionEvents CollectionEvent[]

  @@index([userId])
  @@index([scope])
}

model CollectionEvent {
  id         String @id @default(cuid())
  position   Int

  collectionId String
  eventId      String

  collection Collection    @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  event      TimelineEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([collectionId, eventId])
  @@index([collectionId, position])
  @@index([eventId])
}
